#include <stdio.h>

typedef struct{
    char nome[18];
    int qnt;
    float custo;
}Ferramenta;

int main(){

    FILE *fPtr;

    fPtr = fopen("ferramentas.dat", "w");
    Ferramenta fe = {"", 0, 0};

    for(int i =0; i<100; i++){
        fwrite(&fe, sizeof(Ferramenta), 1, fPtr);
    }

    fclose(fPtr);

    return 0;
}